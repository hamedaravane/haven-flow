{
  "name": "HavenFlow",
  "short_name": "HavenFlow",
  "description": "Your household finance and pantry companion",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait-primary",
  "background_color": "#EFF6FF",
  "theme_color": "#3B82F6",
  "categories": ["finance", "lifestyle", "utilities"],
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Home",
      "url": "/dashboard",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Shopping List",
      "short_name": "Shopping",
      "url": "/shopping-list",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Inventory",
      "short_name": "Pantry",
      "url": "/inventory",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Add Transaction",
      "short_name": "Spend",
      "url": "/transactions",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    }
  ]
}
