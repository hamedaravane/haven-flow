# ─── Database ───────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string used by Drizzle ORM and Better Auth.
# For local dev: adjust host/user/pass to match your local Postgres instance.
# For Docker Compose: the DATABASE_URL is set automatically via docker-compose.yml.
DATABASE_URL="postgresql://havenflow:havenflow_password@localhost:5432/havenflow"

# ─── Better Auth ────────────────────────────────────────────────────────────────
# Secret key used to sign sessions — REQUIRED.
# Generate a secure value with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace_me_with_a_random_32_byte_secret"

# Public base URL of the app (used by Better Auth for CSRF / redirects).
# Update this to your domain in production (e.g. https://havenflow.example.com).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Web Push Notifications (VAPID) ─────────────────────────────────────────────
# Optional — the app runs without push notifications if these are not set.
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="replace_me_with_vapid_public_key"
VAPID_PRIVATE_KEY="replace_me_with_vapid_private_key"
# Email shown in VAPID headers (must be a mailto: URI)
VAPID_SUBJECT="mailto:admin@havenflow.local"

# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV="development"

# ─── Docker Notes ───────────────────────────────────────────────────────────────
# When running with Docker Compose, create a .env file (copy this template) and
# set BETTER_AUTH_SECRET, NEXT_PUBLIC_APP_URL, and optionally VAPID_* keys.
# The DATABASE_URL is automatically provided by docker-compose.yml.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env — set BETTER_AUTH_SECRET at minimum
#   docker compose up --build
#
# The app will be available at http://localhost:3000
